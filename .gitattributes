# Pin line endings so Windows users with core.autocrlf=true don't see
# "LF will be replaced by CRLF" warnings on every `git add`. Shell scripts
# and most text files use LF; .bat/.cmd need CRLF for cmd.exe.

* text=auto eol=lf

*.sh        text eol=lf
*.bash      text eol=lf
*.ps1       text eol=lf
*.psm1      text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.iss       text eol=lf
*.http      text eol=lf
*.toml      text eol=lf

*.bat       text eol=crlf
*.cmd       text eol=crlf

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
